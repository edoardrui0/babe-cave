---
// Utils
import { getImage, Picture } from "astro:assets";

// Components
import BaseLayout from "@layouts/BaseLayout.astro";
import SBS2295 from "@components/SideBySide/sbs-2295.astro";
import Steps1893 from "@components/Steps/steps-1893.astro";
import Reviews2011 from "@components/Testimonials/reviews-2011.astro";
import CTA697 from "@components/CTA/CTA-697.astro";

// Images
import landingImage from "@assets/images/landing.jpg";
import cuttingEquip from "@assets/images/about/cutting-equip.jpg";
import pfpBriLarge from "@assets/images/gallery/pfp-bri-large.jpeg";
import studio from "@assets/images/studio/studio.jpeg";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout
	title="About"
	description="Meet Bri Hill, the hair artist and extension specialist behind Babe Cave in Land O' Lakes, FL. Judgment-free and all about your dream hair."
	heroImage={optimizedImage}
>
	<!-- ============================================ -->
	<!--                 Side By Side                 -->
	<!-- ============================================ -->

	<section id="sbs-1014">
		<div class="cs-container">
			<!-- Left Image Section -->
			<div class="cs-image-group">
				<Picture
					src={pfpBriLarge}
					alt="Bri Hill, hair artist and blonde specialist at Babe Cave"
					width="522"
					height="581"
					loading="lazy"
					decoding="async"
					pictureAttributes={{ class: "cs-picture cs-picture1" }}
				/>
				<Picture
					src={studio}
					alt="Inside Bri's relaxing private studio suite"
					width="414"
					height="400"
					loading="lazy"
					decoding="async"
					pictureAttributes={{ class: "cs-picture cs-picture2" }}
				/>
			</div>
			<!-- Right Content Section-->
			<div class="cs-content">
				<span class="cs-topper">About Us</span>
				<h2 class="cs-title">Meet Bri, Your Hair Artist</h2>
				<p class="cs-text">
					Bri Hill is the hair artist and extension specialist behind Babe Cave,
					working out of a relaxing private suite in Land O' Lakes. She trained
					at Hillsborough College and built her business on one simple idea:
					every person who sits in her chair should leave feeling more confident
					than when they walked in.
				</p>
				<p class="cs-text">
					Bri is known for her blonde work, from soft buttery balayage to full
					color correction, plus cuts, extensions, treatments, and more. She
					takes the time to really get to know your hair so she can keep it
					healthy through the process, not just make it look good for a day.
					Judgment-free, Babe Cave is a space where new guests are always
					welcome and your look is always custom to you.
				</p>
				<div class="cs-quote">
					<span class="cs-quote-text">
						When you feel good about your hair, you carry yourself differently.
						That's what I want for everyone who sits in my chair, hair that
						feels like the best version of you.
					</span>
					<span class="cs-name">Bri Hill</span>
					<span class="cs-job">Owner & Stylist</span>
					<img
						class="cs-quote-icon"
						loading="lazy"
						decoding="async"
						src="https://csimg.nyc3.digitaloceanspaces.com/SideBySide/quote-white.svg"
						alt="gavel"
						width="136"
						height="77"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- ============================================ -->
	<!--                    CTA                       -->
	<!-- ============================================ -->

	<section id="cta-1014">
		<div class="cs-container">
			<div class="cs-left-section">
				<h2 class="cs-title">Ready to Book Your Appointment?</h2>
				<div class="cs-cta-group">
					<a href="/contact/" class="cs-button-solid">Book an Appointment</a>
					<a
						href="https://booksy.com/en-us/1769740_babe-cave_hair-salon_119784_central-pasco#ba_s=seo"
						class="cs-button-solid"
						target="_blank"
						rel="noopener">Book on Booksy</a
					>
				</div>
			</div>
			<div class="cs-content">
				<span class="cs-header">Salon Hours</span>
				<p class="cs-p">
					Sunday: Closed<br />
					Monday - Thursday: 9:00 AM - 8:00 PM<br />
					Friday: 10:00 AM - 6:00 PM<br />
					Saturday: 10:00 AM - 3:00 PM
				</p>
				<p class="cs-p">
					New guests welcome. Book through
					<a
						href="https://booksy.com/en-us/1769740_babe-cave_hair-salon_119784_central-pasco#ba_s=seo"
						target="_blank"
						rel="noopener">Booksy</a
					>, or DM @babecave.bri to get on the schedule.
				</p>
			</div>
			<Picture
				src={cuttingEquip}
				alt="Hair cutting tools and equipment at Babe Cave"
				width="275"
				height="132"
				loading="lazy"
				decoding="async"
				pictureAttributes={{ class: "cs-background", "aria-hidden": "true" }}
			/>
		</div>
	</section>

	<SBS2295 />
	<Steps1893 />
	<Reviews2011 />
	<CTA697 />
</BaseLayout>

<style lang="less">
	/*-- -------------------------- -->
<---       Side By Side         -->
<--- -------------------------- -*/

	/* Mobile - 360px */
	@media only screen and (min-width: 0rem) {
		#sbs-1014 {
			padding: var(--sectionPadding);
			padding-top: (200/16rem);
			background-color: #fbf5f1;

			.cs-container {
				width: 100%;
				max-width: (1280/16rem);
				margin: auto;
				display: flex;
				flex-direction: column;
				align-items: center;
				/* 48px - 64px */
				gap: clamp(3rem, 6vw, 4rem);
			}

			.cs-content {
				/* set text align to left if content needs to be left aligned */
				text-align: left;
				width: 100%;
				max-width: (542/16rem);
				display: flex;
				flex-direction: column;
				/* centers content horizontally, set to flex-start to left align */
				align-items: flex-start;
			}

			.cs-text {
				font-size: var(--bodyFontSize);
				line-height: 1.5em;
				text-align: inherit;
				width: 100%;
				max-width: (650/16rem);
				margin: 0;
				color: var(--bodyTextColor);
			}

			.cs-text {
				margin-bottom: (16/16rem);
				&:last-of-type {
					margin-bottom: (32/16rem);
				}
			}

			.cs-quote {
				margin: 0 0 (32/16rem) 0;
				/* 16px - 32px */
				padding: clamp(1rem, 3vw, 2rem);
				background-color: #1a1a1a;
				position: relative;
			}

			.cs-quote-text {
				/* 14px - 16px */
				font-size: clamp(0.875rem, 1.5vw, 1rem);
				line-height: 1.5em;
				margin: 0 0 (16/16rem);
				color: var(--bodyTextColorWhite);
				display: block;
			}

			.cs-name {
				font-size: (16/16rem);
				line-height: 1.2em;
				text-transform: uppercase;
				font-weight: bold;
				margin: 0 0 (4/16rem);
				color: var(--primary);
				display: block;
			}

			.cs-job {
				font-size: (14/16rem);
				line-height: 1.5em;
				color: var(--bodyTextColorWhite);
				display: block;
			}

			.cs-quote-icon {
				/* 60px - 136px */
				width: clamp(3.75rem, 10vw, 8.5rem);
				height: auto;
				position: absolute;
				bottom: (0/16rem);
				/* 16px - 32px */
				right: clamp(1rem, 4vw, 2rem);
			}

			.cs-image-group {
				/* scaling the font size with the view width */
				font-size: ~"min(2.31vw, .7em)";
				/* using ems so we can use font size to scale the whole section */
				width: (631/16em);
				height: (636/16em);
				position: relative;
			}

			.cs-picture {
				position: absolute;
				display: block;

				img {
					position: absolute;
					top: 0;
					left: 0;
					height: 100%;
					width: 100%;
					/* makes image act like a background image */
					object-fit: cover;
				}
			}

			.cs-picture1 {
				width: (522/16em);
				height: (581/16em);
				left: 0;
				top: 0;
			}

			.cs-picture2 {
				width: (414/16em);
				height: (400/16em);
				background-color: #fff;
				box-shadow: rgba(0, 0, 0, 0.1) 0px 0px 40px;
				/* 6px - 12px */
				border: clamp(0.375em, 1.5vw, 0.75em) solid #fff;
				right: 0;
				bottom: 0;
			}
		}
	}

	/* Desktop - 1024px */
	@media only screen and (min-width: 64rem) {
		#sbs-1014 {
			.cs-container {
				flex-flow: row;
				justify-content: space-between;
				gap: (52/16rem);
			}

			.cs-image-group {
				font-size: ~"min(1.2vw, 1em)";
				flex: none;
			}

			.cs-content {
				margin: 0;
			}
		}
	}

	/* Dark Mode */
	@media only screen and (min-width: 0rem) {
		body.dark-mode {
			#sbs-1014 {
				background-color: rgba(0, 0, 0, 0.2);
				.cs-image-group {
					&:before,
					&:after {
						background: var(--accent);
					}
				}

				.cs-picture2 {
					background-color: var(--dark);
					/* 6px - 12px */
					border: clamp(0.375em, 1.5vw, 0.75em) solid var(--dark);
				}

				.cs-title,
				.cs-text,
				.cs-h3,
				.cs-quote-text,
				.cs-name {
					color: var(--bodyTextColorWhite);
				}

				.cs-quote {
					background-color: rgba(0, 0, 0, 0.6);
				}

				.cs-job {
					color: var(--bodyTextColorWhite);
					opacity: 0.8;
				}

				.cs-quote-icon {
					opacity: 0.2;
				}
			}
		}
	}

	/*-- -------------------------- -->
<---            CTA             -->
<--- -------------------------- -*/

	/* Mobile - 360px */
	@media only screen and (min-width: 0rem) {
		#cta-1014 {
			padding: var(--sectionPadding);

			.cs-container {
				width: 100%;
				max-width: (1280/16rem);
				margin: auto;
				/* 32px - 88px top & bottom */
				/* 24px - 88px left & right */
				padding: clamp(2em, 6.3vw, 5.5em) clamp(1.5em, 5.7vw, 5.5em);
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				justify-content: center;
				gap: (32/16rem);
				position: relative;
				/* clips the corners for the border radius to show */
				overflow: hidden;
				z-index: 1;
				/* prevents padding from adding to height and width */
				box-sizing: border-box;
			}

			.cs-background {
				width: 100%;
				height: 100%;
				position: absolute;
				top: 0;
				left: 0;
				display: block;
				z-index: -1;

				&:before {
					/* black overlay */
					content: "";
					width: 100%;
					height: 100%;
					background: #000;
					opacity: 0.8;
					position: absolute;
					display: block;
					top: 0;
					left: 0;
					z-index: 1;
				}

				img {
					position: absolute;
					top: 0;
					left: 0;
					height: 100%;
					width: 100%;
					object-fit: cover;
				}
			}

			.cs-left-section {
				max-width: (434/16rem);
			}

			.cs-title {
				font-size: var(--headerFontSize);
				font-weight: 900;
				line-height: 1.2em;
				text-align: left;
				max-width: (800/16rem);
				/* 20px - 48px */
				margin: 0 auto clamp(1.25rem, 4.7vw, 3rem);
				color: var(--bodyTextColorWhite);
				position: relative;
			}

			.cs-button-solid {
				font-size: (16/16rem);
				/* 46px - 56px */
				line-height: clamp(2.875em, 5.5vw, 3.5em);
				text-decoration: none;
				font-weight: 700;
				text-align: center;
				margin: auto;
				color: #fff;
				min-width: (150/16rem);
				padding: 0 (32/16rem);
				background-color: var(--primary);
				display: inline-block;
				position: relative;
				z-index: 1;
				/* prevents padding from adding to the width */
				box-sizing: border-box;

				&:before {
					content: "";
					position: absolute;
					height: 100%;
					width: 0%;
					background: #000;
					opacity: 1;
					top: 0;
					left: 0;
					z-index: -1;
					transition: width 0.3s;
				}

				&:hover {
					&:before {
						width: 100%;
					}
				}
			}

			.cs-cta-group {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: (16/16rem);
			}

			.cs-content {
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: flex-start;
				/* 12px - 20px */
				gap: clamp(0.75rem, 1.6vw, 1.25rem);
				max-width: (800/16rem);
			}

			.cs-header {
				/* 20px - 25px */
				font-size: clamp(1.25rem, 2.4vw, 1.5625rem);
				font-weight: bold;
				color: var(--primary);
				display: block;
			}

			.cs-p {
				/* 14px - 20px */
				font-size: clamp(0.875rem, 1.5vw, 1.25rem);
				line-height: 1.5em;
				margin: 0;
				color: var(--bodyTextColorWhite);
			}
		}
	}

	/* Tablet - 768px */
	@media only screen and (min-width: 48rem) {
		#cta-1014 {
			.cs-container {
				flex-direction: row;
				justify-content: space-between;
			}

			.cs-content {
				align-items: flex-end;
				text-align: right;
				/* prevents flexbox from squishing it */
				flex: none;
			}
		}
	}

	/* Dark Mode */
	@media only screen and (min-width: 0rem) {
		body.dark-mode {
			#cta-1014 {
				.cs-background {
					&:before {
						opacity: 0.9;
					}
					&:after {
						opacity: 0.1;
					}
				}
			}
		}
	}
</style>
