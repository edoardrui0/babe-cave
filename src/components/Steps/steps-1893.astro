---
import { Picture } from "astro:assets";

import hair8 from "@assets/images/gallery/hair-8.jpeg";
---

<section id="steps-1893">
  <div class="cs-container">
    <div class="cs-image-group">
      <Picture
        src={hair8}
        alt="Root touch-up blended into a soft, buttery blonde"
        width="324"
        height="467"
        loading="lazy"
        decoding="async"
        pictureAttributes={{ class: "cs-picture" }}
      />
      <img
        class="cs-graphic cs-brown"
        loading="lazy"
        decoding="async"
        src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Graphics/brown-lines2.svg"
        alt="graphic"
        width="100"
        height="98"
        aria-hidden="true"
      />
      <img
        class="cs-graphic cs-peach"
        loading="lazy"
        decoding="async"
        src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/peach-blob.svg"
        alt="graphic"
        width="42"
        height="31"
        aria-hidden="true"
      />
      <img
        class="cs-graphic cs-leaf"
        loading="lazy"
        decoding="async"
        src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Graphics/leaf-reverse.svg"
        alt="graphic"
        width="136"
        height="171"
        aria-hidden="true"
      />
      <img
        class="cs-graphic cs-dots"
        loading="lazy"
        decoding="async"
        src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Icons/beige-dots.svg"
        alt="graphic"
        width="159"
        height="88"
        aria-hidden="true"
      />
      <img
        class="cs-graphic cs-lines"
        loading="lazy"
        decoding="async"
        src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Graphics/mesh-reverse.svg"
        alt="graphic"
        width="150"
        height="165"
        aria-hidden="true"
      />
    </div>
    <div class="cs-wrapper">
      <div class="cs-content">
        <span class="cs-topper">How to get started</span>
        <h2 class="cs-title">3 Easy Steps to Love Your Hair</h2>
      </div>
      <ul class="cs-card-group">
        <li class="cs-item">
          <span class="cs-number">01</span>
          <div class="cs-flex">
            <h3 class="cs-h3">Book Your Appointment</h3>
            <p class="cs-item-text">
              Book through
              <a
                href="https://booksy.com/en-us/1769740_babe-cave_hair-salon_119784_central-pasco#ba_s=seo"
                target="_blank"
                rel="noopener">Booksy</a
              >, or send a DM to @babecave.bri on Instagram. New guests are
              always welcome and scheduling is flexible.
            </p>
          </div>
        </li>
        <li class="cs-item">
          <span class="cs-number">02</span>
          <div class="cs-flex">
            <h3 class="cs-h3">Relax and Get Pampered</h3>
            <p class="cs-item-text">
              Settle into Bri's private suite in Land O' Lakes while she listens
              to your goals, gets to know your hair, and brings your vision to
              life.
            </p>
          </div>
        </li>
        <li class="cs-item">
          <span class="cs-number">03</span>
          <div class="cs-flex">
            <h3 class="cs-h3">Walk Out Feeling Amazing</h3>
            <p class="cs-item-text">
              Leave knowing your hair looks and feels its absolute best. Bri
              will show you how to keep that glow going between appointments.
            </p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>

<style lang="less">
  /* Mobile - 360px */
  @media only screen and (min-width: 0rem) {
    #steps-1893 {
      padding: var(--sectionPadding);
      background-color: #fff;
      overflow: hidden;
      position: relative;
      z-index: 1;

      .cs-container {
        width: 100%;
        /* changes to 1280px at desktop */
        max-width: (704/16rem);
        margin: auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: (32/16rem);
      }

      .cs-image-group {
        font-size: min(2.24vw, 0.9rem);
        width: (482/16em);
        height: (616/16em);
        display: block;
        position: relative;
        z-index: 1;
      }

      .cs-picture {
        width: (413/16em);
        height: (593/16em);
        margin-top: (24/16em);
        box-sizing: border-box;
        background-color: #dab692;
        overflow: hidden;
        border: 8px solid #dab692;
        border-radius: (260/16rem);
        position: absolute;
        right: 0;
        z-index: -1;

        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          position: absolute;
          top: 0;
          left: 0;
          transition: transform 0.7s;
        }
      }

      .cs-graphic {
        height: auto;
        position: absolute;
      }

      .cs-brown {
        width: (165/16em);
        height: auto;
        top: (20/16em);
        left: (24/16em);
        z-index: -2;
        transform: rotate(140deg);
      }

      .cs-peach {
        width: (69/16em);
        height: auto;
        top: (16/16em);
        left: (140/16em);
        transform: rotate(-40deg);
      }

      .cs-leaf {
        width: (224/16em);
        height: auto;
        bottom: (0/16em);
        right: (16/16em);
        z-index: 1;
      }

      .cs-dots {
        width: (261/16em);
        height: auto;
        left: (16/16em);
        bottom: (16/16em);
        z-index: -2;
      }

      .cs-lines {
        width: (246/16em);
        right: 0;
        bottom: (0/16em);
      }

      .cs-wrapper {
        display: flex;
        flex-direction: column;
        /* 48px - 64px */
        gap: clamp(3rem, 6vw, 4rem);
      }

      .cs-content {
        /* set text align to left if content needs to be left aligned */
        text-align: left;
        width: 100%;
        display: flex;
        flex-direction: column;
        /* centers content horizontally, set to flex-start to left align */
        align-items: flex-start;
      }

      .cs-topper {
        color: var(--secondary);
      }

      .cs-title {
        margin: 0;
      }

      .cs-card-group {
        margin: 0;
        padding: 0;
        display: grid;
        align-items: stretch;
        grid-auto-flow: row;
        /* 24px - 32px */
        gap: clamp(1.5rem, 3vw, 2rem);
      }

      .cs-item {
        list-style: none;
        padding-bottom: (32/16rem);
        border-bottom: #ded1bd 1px solid;
        display: flex;
        align-items: flex-start;
        /* 16px - 24px */
        gap: clamp(1rem, 2vw, 1.5rem);
        position: relative;

        &:last-of-type {
          border-bottom: none;
        }
      }

      .cs-number {
        /* 49px - 72px */
        font-size: clamp(3.0625rem, 6vw, 4.5rem);
        font-weight: 900;
        line-height: (19/16em);
        // color: var(--primary);
        opacity: 0.2;
        display: block;
      }

      .cs-h3 {
        /* 20px - 25px */
        font-size: clamp(1.25rem, 2.5vw, 1.5625rem);
        font-weight: 700;
        line-height: (18/16em);
        margin: 0 0 (12/16rem) 0;
        color: var(--headerColor);
      }

      .cs-item-text {
        font-size: (16/16rem);
        line-height: (24/16em);
        text-align: left;
        margin: 0;
        color: var(--bodyTextColor);
      }
    }
  }

  /* Tablet - 768px */
  @media only screen and (min-width: 48rem) {
    #steps-1893 {
      .cs-container {
        max-width: (1280/16rem);
        flex-direction: row;
        align-items: stretch;
        /* 48px - 60px */
        gap: clamp(3rem, 6vw, 3.75rem);
      }

      .cs-card-group {
        /* 16px - 32px */
        gap: clamp(1rem, 3vw, 2rem);
      }

      .cs-item {
        flex-direction: row;
      }

      .cs-image-group {
        font-size: min(1.5vw, 1rem);
        height: auto;
        min-height: (616/16em);
        flex: none;
        /* sends it to the right in the 2nd position */
        order: 2;
      }

      .cs-picture {
        height: 96.266234%;
      }
    }
  }

  /* Dark Mode */
  @media only screen and (min-width: 0rem) {
    body.dark-mode {
      #steps-1893 {
        background-color: rgba(0, 0, 0, 0.2);

        .cs-picture {
          border-color: var(--accent);
        }

        .cs-graphic {
          opacity: 0.6;
        }

        .cs-peach {
          opacity: 1;
          filter: brightness(60%);
        }

        .cs-number {
          color: var(--primaryLight);
          opacity: 0.6;
        }

        .cs-title,
        .cs-h3,
        .cs-item-text {
          color: var(--bodyTextColorWhite);
        }

        .cs-item {
          border-color: rgba(255, 255, 255, 0.2);
        }

        .cs-item-text {
          opacity: 0.8;
        }
      }
    }
  }
</style>
