---
import { Picture } from "astro:assets";

import hair2 from "@assets/images/gallery/hair-2.jpeg";
import hair5 from "@assets/images/gallery/hair-5.jpeg";
import hair7 from "@assets/images/gallery/hair-7.jpeg";
import hair9 from "@assets/images/gallery/hair-9.jpeg";
import hair12 from "@assets/images/gallery/hair-12.jpeg";
---

<section id="gallery-2243">
  <div class="cs-container">
    <div class="cs-content">
      <span class="cs-topper">Our Gallery</span>
      <h2 class="cs-title">Take a Look at Results Guests Actually Love</h2>
      <p class="cs-text">
        From buttery blondes to seamless extensions and fresh cuts, every photo
        is real work straight from Bri's chair. Follow @babecave.bri on
        Instagram to see even more of what's possible.
      </p>
    </div>
    <div class="cs-gallery">
      <Picture
        src={hair2}
        alt="Custom color and toner for a brightened, glowing finish"
        width="380"
        height="271"
        loading="lazy"
        decoding="async"
        pictureAttributes={{ class: "cs-picture cs-picture1" }}
      />
      <Picture
        src={hair5}
        alt="Brightening highlights with shine and dimension"
        width="380"
        height="271"
        loading="lazy"
        decoding="async"
        pictureAttributes={{ class: "cs-picture cs-picture2" }}
      />
      <Picture
        src={hair9}
        alt="Freestyle color creating dimension and glow"
        width="780"
        height="582"
        loading="lazy"
        decoding="async"
        pictureAttributes={{ class: "cs-picture cs-picture3" }}
      />
      <Picture
        src={hair7}
        alt="Custom butterfly layers for a confident, dimensional cut"
        width="380"
        height="271"
        loading="lazy"
        decoding="async"
        pictureAttributes={{ class: "cs-picture cs-picture4" }}
      />
      <Picture
        src={hair12}
        alt="Lob haircut with a seamless, healthy blend"
        width="380"
        height="271"
        loading="lazy"
        decoding="async"
        pictureAttributes={{ class: "cs-picture cs-picture5" }}
      />
    </div>
  </div>
  <div>
    <a href="/gallery/" class="cs-button-solid">View Full Gallery</a>
  </div>
</section>

<style lang="less">
  /*-- -------------------------- -->
<---           Gallery          -->
<--- -------------------------- -*/

  /* Mobile - 360px */
  @media only screen and (min-width: 0rem) {
    #gallery-2243 {
      padding: var(--sectionPadding);
      overflow: hidden;
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      background-color: #fbf5f1;

      .cs-container {
        width: 100%;
        max-width: (1840/16rem);
        margin: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        /* 48px - 64px */
        gap: clamp(3rem, 5vw, 4rem);
        position: relative;
        z-index: 1;
      }

      .cs-content {
        /* aligns text centrally. set to left to left-align text */
        text-align: center;
        pointer-events: none;
        display: flex;
        flex-direction: column;
        justify-content: center;
        /* centrally aligns items. set to flex-start to left-align items */
        align-items: center;
        z-index: 2;
      }

      .cs-title {
        max-width: 40ch;
      }

      .cs-gallery {
        width: 100%;
        height: auto;
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-template-rows: repeat(16, 16.666vw);
        gap: clamp(0.5rem, 2vw, 1.25rem);
      }

      .cs-picture {
        grid-column: span 6;
        display: block;
        position: relative;
        z-index: 1;

        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          position: absolute;
          top: 0;
          left: 0;
        }
      }

      .cs-picture1 {
        grid-row: 2 / span 3;
      }

      .cs-picture2 {
        grid-row: 1 / span 4;
      }

      .cs-picture3 {
        grid-column: span 12;
        grid-row: 5 / span 5;
      }

      .cs-picture4 {
        grid-row: 10 / span 4;
      }

      .cs-picture5 {
        grid-row: 11 / span 3;
      }

      .cs-button-solid {
        margin-top: (32/16rem);
      }
    }
  }

  /* Tablet - 768px */
  @media only screen and (min-width: 48rem) {
    #gallery-2243 {
      .cs-gallery {
        /* 320px - 600px */
        height: clamp(20rem, 41vw, 37.5rem);
        grid-template-columns: repeat(6, 1fr);
        grid-template-rows: repeat(5, 1fr);

        .cs-picture {
          grid-column: span 1;
        }

        .cs-picture1 {
          grid-column: 1 / span 1;
          grid-row: 2 / span 3;
        }

        .cs-picture2 {
          grid-column: 2 / span 1;
          grid-row: 1 / span 4;
        }

        .cs-picture3 {
          grid-column: 3 / span 2;
          grid-row: 1 / span 6;
        }

        .cs-picture4 {
          grid-column: 5 / span 1;
          grid-row: 1 / span 4;
        }

        .cs-picture5 {
          grid-column: 6 / span 1;
          grid-row: 2 / span 3;
        }
      }
    }
  }

  /* Desktop - 1600px */
  @media only screen and (min-width: 100rem) {
    #gallery-2243 {
      .cs-gallery {
        grid-template-columns: repeat(5, 1fr);
        grid-template-rows: repeat(6, 1fr);

        .cs-picture {
          grid-column: span 1;
        }

        .cs-picture1 {
          grid-column: 1 / span 1;
          grid-row: 2 / span 4;
        }

        .cs-picture2 {
          grid-column: 2 / span 1;
          grid-row: 1 / span 5;
        }

        .cs-picture3 {
          grid-column: 3 / span 1;
          grid-row: 1 / span 6;
        }

        .cs-picture4 {
          grid-column: 4 / span 1;
          grid-row: 1 / span 5;
        }

        .cs-picture5 {
          grid-column: 5 / span 1;
          grid-row: 2 / span 4;
        }
      }
    }
  }

  /* Dark Mode */
  @media only screen and (min-width: 0rem) {
    body.dark-mode {
      #gallery-2243 {
        .cs-title,
        .cs-text {
          color: var(--bodyTextColorWhite);
        }

        .cs-text {
          opacity: 0.8;
        }
      }
    }
  }
</style>
